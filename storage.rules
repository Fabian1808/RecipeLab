rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // ==================== HELPERS ====================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isImage() {
      return request.resource.contentType.matches('image/(jpeg|png|webp|gif)');
    }

    function isValidImageSize() {
      return request.resource.size < 5 * 1024 * 1024; // 5 MB
    }

    function isImagePath() {
      return resource.name.startsWith('recetas/');
    }

    // ==================== RECETAS (IMÁGENES) ====================
    
    match /recetas/{fileName} {
      // Lectura pública de imágenes
      allow read: if true;
      
      // Usuario autenticado puede subir imágenes
      allow create: if isAuthenticated() 
                    && isImage() 
                    && isValidImageSize()
                    && fileName.matches(request.auth.uid + '.*');
      
      // Usuario puede eliminar sus propias imágenes
      allow delete: if isAuthenticated() 
                    && fileName.matches(request.auth.uid + '.*');
    }

    // ==================== DEFAULT DENY ====================
    
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
